SECRET_KEY=change-me-to-a-random-string
# Cifrado de datos sensibles (usuarios, pagos). Generar con:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
DATA_ENCRYPTION_KEY=
# PostgreSQL (local dev with Docker) or SQLite (simple deploy):
# DATABASE_URL=postgresql+psycopg://maimjaim:maimjaim@localhost:5432/maimjaim
DATABASE_URL=sqlite:///instance/maimjaim.db
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH_REDIRECT_URI=http://localhost:5000/auth/callback
# For ngrok local testing (see README):
# OAUTH_REDIRECT_URI=https://steady-beetle-alert.ngrok-free.app/auth/callback
# TRUST_PROXY=true
ALLOWED_EMAIL_DOMAIN=
ADMIN_EMAILS=admin@example.com
FLASK_ENV=development
TRUST_PROXY=false
